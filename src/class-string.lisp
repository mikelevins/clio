;;; protocol: math
;;; ---------------------------------------------------------------------
;;; ---------------------------------------------------------------------
;;; protocol: names
;;; ---------------------------------------------------------------------
;;; ---------------------------------------------------------------------
;;; protocol: ordered
;;; ---------------------------------------------------------------------

(defmethod < ((thing1 string) (thing2 string) &rest more-things)
  (cl:apply #'cl:string< thing1 thing2 more-things))

(defmethod <= ((thing1 string) (thing2 string) &rest more-things)
  (cl:apply #'cl:string<= thing1 thing2 more-things))

(defmethod > ((thing1 string) (thing2 string) &rest more-things)
  (cl:apply #'cl:string> thing1 thing2 more-things))

(defmethod >= ((thing1 string) (thing2 string) &rest more-things)
  (cl:apply #'cl:string>= thing1 thing2 more-things))

