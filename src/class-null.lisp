(defmethod = ((thing1 null) (thing2 null) &rest more-things)
  (cl:apply #'cl:eq thing1 thing2 more-things))

(defmethod identical? ((thing1 null) (thing2 null) &rest more-things)
  (cl:apply #'cl:eq thing1 thing2 more-things))

