;;; protocol: characters
;;; ---------------------------------------------------------------------
;;; ---------------------------------------------------------------------
;;; protocol: conditions
;;; ---------------------------------------------------------------------
;;; ---------------------------------------------------------------------
;;; protocol: construction
;;; ---------------------------------------------------------------------

(defmethod make ((type (eql 'eof)) &rest initargs
                 &key &allow-other-keys)
  (make-instance 'eof))

(defun eof ()(make-instance 'eof))

